{
  "name": "claudeplex",
  "version": "0.3.0",
  "description": "A terminal multiplexer & cockpit for Claude Code — monitor and orchestrate multiple Claude Max accounts from one TUI.",
  "type": "module",
  "bin": {
    "claudeplex": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "once": "bun run src/index.ts --once",
    "json": "bun run src/index.ts --json",
    "typecheck": "bunx tsc --noEmit",
    "build": "bun run scripts/build.ts"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "anthropic",
    "cli",
    "tui",
    "terminal",
    "dashboard",
    "multiplexer",
    "orchestrator",
    "ai-agents"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iret77/claudeplex.git"
  },
  "homepage": "https://github.com/iret77/claudeplex#readme",
  "bugs": {
    "url": "https://github.com/iret77/claudeplex/issues"
  },
  "devDependencies": {
    "bun-types": "^1.3.14"
  }
}
