{
  "name": "claude-dashboard",
  "version": "0.1.0",
  "description": "Animated CLI dashboard for the load + current tasks of multiple Claude Code Max instances",
  "type": "module",
  "bin": {
    "claude-dashboard": "src/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
    "once": "bun run src/index.ts --once",
    "json": "bun run src/index.ts --json"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.14"
  }
}
